{
  "name": "lemmascript",
  "version": "0.5.14",
  "description": "A verification toolchain for TypeScript — generates Lean 4 or Dafny from annotated TS",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "lsc": "tools/dist/lsc.js"
  },
  "files": [
    "tools/dist"
  ],
  "scripts": {
    "build": "tsc -p tools/tsconfig.json",
    "prepublishOnly": "npm run build",
    "typecheck": "tsc -p tools/tsconfig.json --noEmit",
    "typecheck:examples": "tsc -p examples/tsconfig.json"
  },
  "dependencies": {
    "lemmascript-claimcheck": "^0.2.0",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/midspiral/LemmaScript"
  },
  "homepage": "https://lemmascript.org",
  "keywords": [
    "lemmascript",
    "verification",
    "formal-verification",
    "verified",
    "typescript",
    "lean4",
    "dafny",
    "formal-methods"
  ]
}
