// Generated by lsc from linearSearch.ts

function linearSearch_loop(arr: seq<int>, target: int, i: nat, result: int): int
  decreases (|arr| - i)
{
  if (i < |arr|) then
    if (arr[i] == target) then
      var result := i;
      result
    else
      var i := (i + 1);
      linearSearch_loop(arr, target, i, result)
  else
    result
}

function linearSearch(arr: seq<int>, target: int): int
{
  linearSearch_loop(arr, target, 0, -1)
}
