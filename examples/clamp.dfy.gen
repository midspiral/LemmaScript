// Generated by lsc from clamp.ts

method clamp(x: int, lo: int, hi: int) returns (res: int)
  requires (lo <= hi)
  ensures (res >= lo)
  ensures (res <= hi)
{
  var result := x;
  if (result < lo) {
    result := lo;
  }
  if (result > hi) {
    result := hi;
  }
  return result;
}

