// Generated by lsc from havoc.ts

method countMatches(items: seq<string>, validKeys: set<string>) returns (res: int)
  ensures (res >= 0)
{
  var count := 0;
  var i_item_idx := 0;
  while i_item_idx < |items|
    invariant (i_item_idx <= |items|)
    invariant (count >= 0)
  {
    var item := items[i_item_idx];
    var cleaned: string := *;
    if (cleaned in validKeys) {
      count := (count + 1);
    }
    i_item_idx := i_item_idx + 1;
  }
  return count;
}
