// Generated by lsc from perm.ts

predicate Perm<T(==)>(a: seq<T>, b: seq<T>) { multiset(a) == multiset(b) }

function countOn(xs: seq<bool>): int
  decreases |xs|
{
  if (|xs| == 0) then
    0
  else
    ((if xs[0] then 1 else 0) + countOn(xs[1..]))
}

lemma countOn_ensures(xs: seq<bool>)
  ensures (0 <= countOn(xs))
  ensures (countOn(xs) <= |xs|)
{
}

