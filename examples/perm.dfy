// countOn is exactly the multiplicity of `true` in the multiset of the list.
// Proof: induct on the list, splitting off the head.
lemma CountOnIsMultisetCount(xs: seq<bool>)
  ensures countOn(xs) == multiset(xs)[true]
  decreases |xs|
{
  if |xs| == 0 {
  } else {
    CountOnIsMultisetCount(xs[1..]);
    assert xs == [xs[0]] + xs[1..];
  }
}

lemma countOnPerm_ensures(xs: seq<bool>, ys: seq<bool>)
  requires Perm(xs, ys)
  ensures (countOn(xs) == countOn(ys))
{
  // Perm(xs, ys) unfolds to multiset(xs) == multiset(ys), so the multiplicity
  // of `true` agrees; countOn is that multiplicity.
  CountOnIsMultisetCount(xs);
  CountOnIsMultisetCount(ys);
}
