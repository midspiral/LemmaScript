// Generated by lsc from maxElement.ts

function maxElement_loop(arr: seq<int>, max: int, i: nat): int
  requires (|arr| > 0)
  decreases (|arr| - i)
{
  if (i < |arr|) then
    if (arr[i] > max) then
      var max := arr[i];
      var i := (i + 1);
      maxElement_loop(arr, max, i)
    else
      var i := (i + 1);
      maxElement_loop(arr, max, i)
  else
    max
}

function maxElement(arr: seq<int>): int
  requires (|arr| > 0)
{
  maxElement_loop(arr, arr[0], 1)
}
