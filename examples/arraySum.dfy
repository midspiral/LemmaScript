// Generated by lsc from arraySum.ts

function arraySum_loop(arr: seq<int>, sum: int, i: nat): int
  decreases (|arr| - i)
{
  if (i < |arr|) then
    var sum := (sum + arr[i]);
    var i := (i + 1);
    arraySum_loop(arr, sum, i)
  else
    sum
}

function arraySum(arr: seq<int>): int
{
  arraySum_loop(arr, 0, 0)
}
