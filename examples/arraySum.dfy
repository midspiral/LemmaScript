// Generated by lsc from arraySum.ts

function sumTo(arr: seq<int>, n: int): int
  requires 0 <= n <= |arr|
{
  if n == 0 then 0 else sumTo(arr, n - 1) + arr[n - 1]
}

method arraySum(arr: seq<int>) returns (res: int)
  ensures (res == sumTo(arr, |arr|))
{
  var sum := 0;
  var i := 0;
  while (i < |arr|)
    invariant (0 <= i)
    invariant (i <= |arr|)
    invariant (sum == sumTo(arr, i))
    decreases (|arr| - i)
  {
    sum := (sum + arr[i]);
    i := (i + 1);
  }
  return sum;
}
