function clampTernary(x: int, lo: int, hi: int): int
  requires (lo <= hi)
{
  if (x < lo) then
    lo
  else
    if (x > hi) then
      hi
    else
      x
}

lemma clampTernary_ensures(x: int, lo: int, hi: int)
  requires (lo <= hi)
  ensures (clampTernary(x, lo, hi) >= lo)
  ensures (clampTernary(x, lo, hi) <= hi)
