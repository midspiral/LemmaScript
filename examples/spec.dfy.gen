function JSFloorDiv(a: int, b: int): int
  requires b != 0
{
  if b > 0 then
    if a >= 0 then a / b
    else -((-a - 1) / b) - 1
  else
    if a <= 0 then (-a) / (-b)
    else -((a - 1) / (-b)) - 1
}

function StringIndexOf(s: string, sub: string): int
{
  StringIndexOfFrom(s, sub, 0)
}

function StringIndexOfFrom(s: string, sub: string, from: nat): int
  decreases |s| - from
{
  if from + |sub| > |s| then -1
  else if s[from..from + |sub|] == sub then from as int
  else StringIndexOfFrom(s, sub, from + 1)
}

datatype Priority = low | medium | high

datatype Expr = lit(val: int) | add(a: int, b: int) | neg(inner: int)

datatype Config = Config(threshold: nat, maxRetries: nat, enabled: bool)

datatype PriorityItem = PriorityItem(level: Priority, value: int)

function evalPartial(e: Expr): int
{
  match e {
    case lit(i_val) =>
      i_val
    case add(i_a, i_b) =>
      (i_a + i_b)
    case _ =>
      0
  }
}

lemma evalPartial_ensures(e: Expr)
  ensures (e.lit? ==> (evalPartial(e) == e.val))
  ensures (e.add? ==> (evalPartial(e) == (e.a + e.b)))
{
}

function evalSwitch(e: Expr): int
{
  match e {
    case lit(i_val) =>
      i_val
    case add(i_a, i_b) =>
      (i_a + i_b)
    case neg(i_inner) =>
      (0 - i_inner)
  }
}

lemma evalSwitch_ensures(e: Expr)
  ensures (e.lit? ==> (evalSwitch(e) == e.val))
  ensures (e.add? ==> (evalSwitch(e) == (e.a + e.b)))
  ensures (e.neg? ==> (evalSwitch(e) == (0 - e.inner)))
{
}

