method tally (s : Shape) return (res : Int)
  ensures res ≥ 10
  do
    let mut n : Int := 0
    if (match s with | .circle => true | _ => false) then
      n := 1
    else if (match s with | .square => true | _ => false) then
      n := 2
    return n + 10
