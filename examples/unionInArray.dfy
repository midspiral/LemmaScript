// Generated by lsc from unionInArray.ts

datatype Shape = circle(r: int) | rect(w: int, h: int)

function area(s: Shape): int
{
  match s {
    case circle(i_s_r) =>
      ((3 * i_s_r) * i_s_r)
    case rect(i_s_w, i_s_h) =>
      (i_s_w * i_s_h)
  }
}

function shapes(): seq<Shape>
{
  [Shape.circle(2), Shape.rect(3, 4)]
}

function oneRect(): seq<Shape>
{
  var xs := [Shape.rect(1, 5)];
  xs
}

function total(): int
{
  var xs := shapes();
  (area(xs[0]) + area(xs[1]))
}
